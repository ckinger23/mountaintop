# Environment (set to 'local' for LocalStack, leave empty for production)
ENV=local

# AWS Configuration (for LocalStack, these are test values)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1

# Production AWS Configuration (uncomment and set these in production)
# AWS_ACCESS_KEY_ID=your_production_key
# AWS_SECRET_ACCESS_KEY=your_production_secret
# AWS_DEFAULT_REGION=your_region

# Table Names
# USERS_TABLE=users
# GAMES_TABLE=games
# PICKS_TABLE=picks
# LEADERBOARD_TABLE=leaderboard

# JWT Secret (for authentication, if needed)
# JWT_SECRET=your_jwt_secret_key_here

# CORS Allowed Origins (comma-separated)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
